AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# OPTION C: Custom TURN server (self-hosted or Twilio/Xirsys)
# TURN_URL=turn:your-server.com:3478,turns:your-server.com:5349
# TURN_USER=username
# TURN_PASS=password
